LLM_PROVIDER=mock
LLM_BASE_URL=http://localhost:11434
LLM_API_KEY=replace-at-runtime
LLM_MODEL=deterministic-underwriter-v1
LLM_CONNECT_TIMEOUT=2s
LLM_READ_TIMEOUT=15s
LLM_MAX_ATTEMPTS=3
LLM_RETRY_BACKOFF=100ms
LLM_FALLBACK_TO_MOCK=false
IDEMPOTENCY_MAX_ENTRIES=1000
IDEMPOTENCY_RETENTION=24h
TASK_CORE_POOL_SIZE=2
TASK_MAX_POOL_SIZE=4
TASK_QUEUE_CAPACITY=100
TASK_MAX_ENTRIES=1000
TASK_RETENTION=24h
